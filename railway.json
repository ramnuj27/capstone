{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK"
    },
    "deploy": {
        "preDeployCommand": "php artisan config:clear && php artisan migrate --force && php artisan db:seed --force",
        "healthcheckPath": "/up",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
